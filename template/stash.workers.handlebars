name: "{{@package 'displayName'}} (Rewrite)"
desc: |-
  {{#each (split (@package 'description') "\n")}}
  {{{this}}}
  {{/each}}
author: |-
  {{#each (@package 'contributors')}}
  {{this}}
  {{/each}}
homepage: "{{@package 'homepage'}}"
icon: "{{@package 'icon'}}"
category: "{{@package 'organizationName'}}"
date: "{{now "yyyy-MM-dd HH:mm:ss"}}"

rules:
  # 🗺️ Amap
  - DOMAIN-SUFFIX,is.autonavi.com,DIRECT
  # 🗺️ Maps
  - DOMAIN,gspe11-2-cn-ssl.ls.apple.com,DIRECT
  - DOMAIN,gspe12-cn-ssl.ls.apple.com,DIRECT
  - DOMAIN,gspe19-cn-ssl.ls.apple.com,DIRECT
  - DOMAIN,gspe19-2-cn-ssl.ls.apple.com,DIRECT
  - DOMAIN,gspe79-cn-ssl.ls.apple.com,DIRECT

http:
  mitm:
    - "configuration.ls.apple.com"
    - "gspe35-ssl.ls.apple.com"
    - "gspe35-ssl.ls.apple.cn"
  url-rewrite:
    # 🗺️ Network Defaults
    - ^https?:\/\/configuration\.ls\.apple\.com\/config\/defaults https://configuration-ls.nanocat.cloud/config/defaults transparent
    # 🗺️ Announcements
    - ^https?:\/\/gspe35-ssl\.ls\.apple\.(com|cn)\/config\/announcements https://gspe35-ssl-ls.nanocat.cloud/config/announcements transparent
    # 🗺️ Resource Manifest
    - ^https?:\/\/gspe35-ssl\.ls\.apple\.(com|cn)\/geo_manifest\/dynamic\/config https://gspe35-ssl-ls.nanocat.cloud/geo_manifest/dynamic/config transparent
