#!name = {{@package 'displayName'}} (Rewrite)
#!desc = {{inline (@package 'description')}}
#!author = {{@package 'contributors'}}
#!homepage = {{@package 'homepage'}}
#!icon = {{@package 'icon'}}
#!tag = {{@package 'organizationName'}}
#!system = {{@package 'system'}}
#!date = {{now "yyyy-MM-dd HH:mm:ss"}}
#!system_version = {{ @package 'systemVersion'}}

# 参数说明：Rewrite 版本不读取本地脚本参数，实际默认值由远端 Worker 配置决定。
# 本地参数版请使用非 Rewrite 的 Loon 插件；其 [Argument] 会显示每个参数的默认值和效果。

[Rule]
# 🗺️ Amap
DOMAIN-SUFFIX,is.autonavi.com,DIRECT
# 🗺️ Maps
DOMAIN,gspe11-2-cn-ssl.ls.apple.com,DIRECT
DOMAIN,gspe12-cn-ssl.ls.apple.com,DIRECT
DOMAIN,gspe19-cn-ssl.ls.apple.com,DIRECT
DOMAIN,gspe19-2-cn-ssl.ls.apple.com,DIRECT
DOMAIN,gspe79-cn-ssl.ls.apple.com,DIRECT

[URL Rewrite]
# 🗺️ Network Defaults
^https?:\/\/configuration\.ls\.apple\.com\/config\/defaults https://configuration-ls.nanocat.cloud/config/defaults header
# 🗺️ Announcements
^https?:\/\/gspe35-ssl\.ls\.apple\.(com|cn)\/config\/announcements https://gspe35-ssl-ls.nanocat.cloud/config/announcements header
# 🗺️ Resource Manifest
^https?:\/\/gspe35-ssl\.ls\.apple\.(com|cn)\/geo_manifest\/dynamic\/config https://gspe35-ssl-ls.nanocat.cloud/geo_manifest/dynamic/config header

[MITM]
hostname = configuration.ls.apple.com, gspe35-ssl.ls.apple.com, gspe35-ssl.ls.apple.cn
