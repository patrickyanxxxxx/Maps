name: "{{@package 'displayName'}}"
desc: |-
  {{#each (split (@package 'description') "\n")}}
  {{{this}}}
  {{/each}}
openUrl: "{{@package 'openUrl'}}"
author: |-
  {{#each (@package 'contributors')}}
  {{this}}
  {{/each}}
homepage: "{{@package 'homepage'}}"
icon: "{{@package 'icon'}}"
category: "{{@package 'organizationName'}}"
date: "{{now "yyyy-MM-dd HH:mm:ss"}}"
version: "{{@package 'version'}}"

# 参数说明：Stash override 无交互参数面板，请修改下方 script 的 argument。
# 默认：CountryCode=US；Dispatcher=AutoNavi；Directions=Apple；RAP=Apple；LocationShift=AutoNavi
# 默认：Earth=Apple；Flyover/Munin/Roads/Satellite=XX；MainlandLayers=EXTENDED；ServiceMode=CN_POI
# 默认：Storage=Argument；LogLevel=WARN；固定 Hybrid.Enabled=true、Hybrid.Mainland3D=ROUTE

rules:
  # 🗺️ Amap
  - DOMAIN-SUFFIX,is.autonavi.com,DIRECT
  # 🗺️ Maps
  - DOMAIN,gspe11-2-cn-ssl.ls.apple.com,DIRECT
  - DOMAIN,gspe12-cn-ssl.ls.apple.com,DIRECT
  - DOMAIN,gspe19-cn-ssl.ls.apple.com,DIRECT
  - DOMAIN,gspe19-2-cn-ssl.ls.apple.com,DIRECT
  - DOMAIN,gspe79-cn-ssl.ls.apple.com,DIRECT

http:
  mitm:
    - "configuration.ls.apple.com"
    - "gspe35-ssl.ls.apple.com, gspe35-ssl.ls.apple.cn"
  script:
    - match: ^https?:\/\/configuration\.ls\.apple\.com\/config\/defaults
      name: GeoServices.request
      type: request
      argument: '{{{scriptParams}}}'
    - match: ^https?:\/\/configuration\.ls\.apple\.com\/config\/defaults
      name: GeoServices.response
      type: response
      require-body: true
      argument: '{{{scriptParams}}}'
    - match: ^https?:\/\/gspe35-ssl\.ls\.apple\.(com|cn)\/config\/announcements
      name: GeoServices.request
      type: request
      argument: '{{{scriptParams}}}'
    - match: ^https?:\/\/gspe35-ssl\.ls\.apple\.(com|cn)\/config\/announcements
      name: GeoServices.response
      type: response
      require-body: true
      binary-mode: true
      argument: '{{{scriptParams}}}'
    - match: ^https?:\/\/gspe35-ssl\.ls\.apple\.(com|cn)\/geo_manifest\/dynamic\/config
      name: GeoServices.request
      type: request
      argument: '{{{scriptParams}}}'
    - match: ^https?:\/\/gspe35-ssl\.ls\.apple\.(com|cn)\/geo_manifest\/dynamic\/config
      name: GeoServices.response
      type: response
      require-body: true
      binary-mode: true
      argument: '{{{scriptParams}}}'

script-providers:
  GeoServices.request:
    url: https://github.com/NSRingo/GeoServices/releases/download/v{{@package 'version'}}/request.bundle.js
    interval: 86400
  GeoServices.response:
    url: https://github.com/NSRingo/GeoServices/releases/download/v{{@package 'version'}}/response.bundle.js
    interval: 86400
