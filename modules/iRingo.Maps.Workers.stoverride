name: " iRingo: 🗺️ Maps (Rewrite)"
desc: |-
  自定义 Maps app
  添加国际版功能
  自定义服务版本
author: |-
  VirgilClyne[https://github.com/VirgilClyne]
homepage: "https://NSRingo.github.io/guide/GeoServices/maps"
icon: "https://developer.apple.com/assets/elements/icons/maps/maps-128x128.png"
category: " iRingo"

rules:
  # 🗺️ Amap
  - DOMAIN-SUFFIX,is.autonavi.com,DIRECT
  # 🗺️ Maps
  - DOMAIN,gspe11-2-cn-ssl.ls.apple.com,DIRECT
  - DOMAIN,gspe12-cn-ssl.ls.apple.com,DIRECT
  - DOMAIN,gspe19-cn-ssl.ls.apple.com,DIRECT
  - DOMAIN,gspe19-2-cn-ssl.ls.apple.com,DIRECT
  - DOMAIN,gspe79-cn-ssl.ls.apple.com,DIRECT

http:
  mitm:
    - "configuration.ls.apple.com"
    - "gspe35-ssl.ls.apple.com"
  url-rewrite:
    # 🗺️ Network Defaults
    - ^https?:\/\/configuration\.ls\.apple\.com\/config\/defaults https://configuration-ls.nanocat.cloud/config/defaults transparent
    # 🗺️ Announcements
    - ^https?:\/\/gspe35-ssl\.ls\.apple\.com\/config\/announcements https://gspe35-ssl-ls.nanocat.cloud/config/announcements transparent
    # 🗺️ Resource Manifest
    - ^https?:\/\/gspe35-ssl\.ls\.apple\.com\/geo_manifest\/dynamic\/config https://gspe35-ssl-ls.nanocat.cloud/geo_manifest/dynamic/config transparent
